# =============================================================================
# Give a Gallon — environment variables
# =============================================================================
# Two places hold config:
#   1. This .env.local (committed template: .env.example) — CLIENT/build-time
#      vars that Vite inlines. Only VITE_* belongs here.
#   2. The Convex deployment — SERVER-side secrets. Set these with:
#         bunx convex env set NAME "value"
#      (never commit real secret values).
# =============================================================================

# -- Client (Vite) ------------------------------------------------------------
# Your Convex deployment URL (Convex dashboard → Settings → URL & Deploy Key).
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Set to "true" on preview deployments to expose the test-user login shortcut.
# VITE_IS_PREVIEW=false

# -- Convex server secrets (set via `bunx convex env set ...`) -----------------
# Public site URL — used for auth redirects and Stripe success/cancel URLs.
#   bunx convex env set SITE_URL "https://give-a-gallon.vercel.app"
#
# Stripe (Dashboard → Developers):
#   bunx convex env set STRIPE_SECRET_KEY "sk_live_..."        # API key
#   bunx convex env set STRIPE_WEBHOOK_SECRET "whsec_..."      # Webhook signing secret
#   Register the webhook endpoint at: <your-convex-site-url>/stripe-webhook
#   (Convex "site" URL ends in .convex.site; listen for checkout.session.completed)
#
# Resend — email for OTP verification + password reset (optional).
#   When RESEND_API_KEY is set, sign-up email verification + password reset
#   turn on automatically. Leave unset to keep password-only auth.
#   bunx convex env set RESEND_API_KEY "re_..."
#   bunx convex env set RESEND_FROM_EMAIL "noreply@yourdomain.com"
#
# Auth — JWT signing key for Convex Auth (generated during `convex auth` setup).
#   bunx convex env set AUTH_PRIVATE_KEY "..."
